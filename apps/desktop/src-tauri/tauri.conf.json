{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LooksLikeNative",
  "version": "0.1.0",
  "identifier": "com.chiehliu.looks-like-native",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LooksLikeNative",
        "width": 480,
        "height": 160,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "global-shortcut": {
      "shortcuts": ["CmdOrCtrl+Shift+F"]
    }
  }
}
